# App environment
NODE_ENV=development

# JWT secret used to sign and verify access/refresh tokens
JWT_SECRET=replace-with-a-strong-secret

# Prisma/PostgreSQL connection strings
# Pooled connection (recommended for the app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Direct connection (optional, used by seed/migrations when available)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
